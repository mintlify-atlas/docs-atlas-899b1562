  "keyFeatures": [
    "Intelligent Diagnostics with AI-powered sentiment analysis and risk assessment",
    "24/7 Virtual Mentorship using Claude AI for healthcare professionals",
    "Microlearning platform with personalized course recommendations",
    "Gamification system with points, badges, levels, and leaderboards",
    "Real-time wellness heatmaps and smart alerts for departments",
    "Automated pattern detection for employee turnover risk",
    "Socket.IO integration for real-time notifications",
    "Comprehensive JWT authentication and role-based access control"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - User registration",
    "POST /api/auth/login - User authentication",
    "GET /api/auth/profile - Get user profile",
    "POST /api/employees - Create employee",
    "GET /api/employees/:id - Get employee details",
    "POST /api/diagnostic/survey/quick - Submit quick wellness survey",
    "GET /api/diagnostic/wellness-heatmap/:hospitalId - Get wellness heatmap",
    "GET /api/diagnostic/alerts - Get smart alerts",
    "POST /api/mentorship/ask - Ask virtual mentor",
    "GET /api/microlearning/courses - List available courses",
    "POST /api/microlearning/courses/:courseId/enroll - Enroll in course",
    "POST /api/microlearning/courses/:courseId/quiz - Submit quiz",
    "GET /api/microlearning/recommendations/:employeeId - Get course recommendations",
    "POST /api/recognition/grant - Grant recognition to employee",
    "GET /api/recognition/wall/:hospitalId - Get recognition wall",
    "GET /api/recognition/stats/:employeeId - Get gamification stats",
    "POST /api/correlation/analyze - Analyze performance correlations",
    "POST /api/chat/complete - Generate AI response with Claude",
    "GET /api/chat/history - Get conversation history",
    "GET /api/prompts - List prompt templates"
  ]
